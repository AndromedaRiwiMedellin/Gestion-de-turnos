@using ShiftManagement.Models

@{
    Layout = null;
    ViewData["Title"] = "Registro de paciente";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ShiftManagement</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body, html {
            height: 100%;
            margin: 0;
            background-color: #f8f9fa;
        }
        .full-center-container {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }
    </style>
</head>
<body>
    <div class="full-center-container">
        <div class="container">
            <div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-primary text-white fw-semibold">
                Módulo de entrada - Registro del paciente
            </div>

            <div class="card-body p-4">
                <form asp-controller="Turn" asp-action="RegisterPatient" method="post">
                    @Html.AntiForgeryToken()

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">
                            @TempData["Error"]
                        </div>
                    }

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3"></div>
                    }

                    <div class="mb-3">
                        <label for="documentType" class="form-label">
                            Tipo de documento
                        </label>

                        <select id="documentType"
                                name="documentType"
                                class="form-select"
                                required>
                            <option value="@DocumentType.NationalId">Cédula</option>
                            <option value="@DocumentType.Passport">Pasaporte</option>
                            <option value="@DocumentType.ForeignId">Cédula de extranjería</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="documentNumber" class="form-label">
                            Número de documento
                        </label>

                        <input id="documentNumber"
                               type="text"
                               name="documentNumber"
                               class="form-control"
                               placeholder="Ej: 1020304050"
                               required
                               minlength="8"
                               maxlength="15"
                               pattern="\d{8,15}"
                               title="El documento debe tener entre 8 y 15 dígitos" />
                    </div>

                    <div class="mb-3">
                        <label for="fullname" class="form-label">
                            Nombre completo
                        </label>

                        <input id="fullname"
                               type="text"
                               name="fullname"
                               class="form-control"
                               placeholder="Nombre completo del paciente"
                               required
                               maxlength="200"
                               pattern="[a-zA-ZáéíóúÁÉÍÓÚñÑ\s]+"
                               title="El nombre solo puede contener letras" />
                    </div>

                    <div class="mb-3">
                        <label for="phone" class="form-label">
                            Teléfono
                        </label>

                        <input id="phone"
                               type="text"
                               name="phone"
                               class="form-control"
                               placeholder="Teléfono de contacto"
                               minlength="10"
                               maxlength="20"
                               pattern="\d{10,}"
                               title="El teléfono debe tener al menos 10 dígitos" />
                    </div>

                    <div class="mb-4">
                        <label for="email" class="form-label">
                            Correo electrónico
                        </label>

                        <input id="email"
                               type="email"
                               name="email"
                               class="form-control"
                               placeholder="correo@ejemplo.com"
                               required
                               maxlength="200" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        Continuar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
        </div>
    </div>
</body>
</html>