@model string
@{ Layout = null; }

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Sistema de Turnos</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: #f5f7fa;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .card {
            background: white;
            border-radius: 24px;
            padding: 60px 80px;
            text-align: center;
            box-shadow: 0 4px 30px rgba(0,0,0,0.08);
            max-width: 420px;
            width: 90%;
            border: 1px solid #eee;
        }

        .logo {
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 3px;
            color: #1a73e8;
            text-transform: uppercase;
            margin-bottom: 30px;
        }

        .divider {
            height: 1px;
            background: #f0f0f0;
            margin-bottom: 36px;
        }

        .icono { font-size: 56px; margin-bottom: 16px; }

        h1 {
            font-size: 24px;
            color: #1a1a2e;
            font-weight: 700;
            margin-bottom: 10px;
        }

        p {
            color: #aaa;
            font-size: 14px;
            margin-bottom: 40px;
            line-height: 1.6;
        }

        .btn {
            font-size: 17px;
            padding: 16px 52px;
            background: #1a73e8;
            color: white;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            font-weight: 700;
            transition: all 0.2s;
            box-shadow: 0 4px 15px rgba(26,115,232,0.3);
        }

        .btn:hover {
            background: #1558b0;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(26,115,232,0.4);
        }

        .btn:active { transform: scale(0.97); }

        .footer { margin-top: 28px; font-size: 12px; color: #ccc; }
    </style>
</head>
<body>
    <div class="card">
        <div class="logo">⚡ ShiftManagement</div>
        <div class="divider"></div>
        <div class="icono">🎫</div>
        <h1>Sistema de Turnos</h1>
        <p>Presiona el botón para obtener<br>tu número de turno</p>
        <form method="post" action="/Turn/RequestTurn">
            <button type="submit" class="btn">Solicitar Turno</button>
        </form>
        <div class="footer">El ticket se imprimirá automáticamente</div>
    </div>
</body>
</html>