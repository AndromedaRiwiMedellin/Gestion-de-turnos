@using ShiftManagement.Models

@{
ViewData["Title"] = "Registro de paciente";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">
                Módulo de entrada - Registro del paciente
            </div>

            <div class="card-body">
                <form asp-controller="Turn" asp-action="RegisterPatient" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label">Tipo de documento</label>
                        <select name="documentType" class="form-select" required>
                            <option value="@DocumentType.NationalId">Cédula</option>
                            <option value="@DocumentType.Passport">Pasaporte</option>
                            <option value="@DocumentType.ForeignId">Cédula de extranjería</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Número de documento</label>
                        <input type="text"
                               name="documentNumber"
                               class="form-control"
                               placeholder="Ej: 1020304050"
                               required
                               maxlength="50" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Nombre completo</label>
                        <input type="text"
                               name="fullname"
                               class="form-control"
                               placeholder="Nombre completo del paciente"
                               required
                               maxlength="200" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Teléfono</label>
                        <input type="text"
                               name="phone"
                               class="form-control"
                               placeholder="Teléfono de contacto"
                               maxlength="20" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Correo electrónico</label>
                        <input type="email"
                               name="email"
                               class="form-control"
                               placeholder="correo@ejemplo.com"
                               maxlength="200" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        Continuar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>