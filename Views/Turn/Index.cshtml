@{
    ViewData["Title"] = "Request Turn";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <h2 class="mb-4">Request a Turn</h2>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        <form method="post" asp-action="RequestTurn">
            <div class="mb-3">
                <label class="form-label">Document Type</label>
                <select name="documentType" class="form-select">
                    <option value="0">National ID</option>
                    <option value="1">Passport</option>
                    <option value="2">Foreign ID</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Document Number</label>
                <input name="documentNumber" type="text" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-primary w-100">Get Turn</button>
        </form>

        <div class="mt-3 text-center">
            <a asp-controller="User" asp-action="Register">Not registered yet? Register here</a>
        </div>
    </div>
</div>
