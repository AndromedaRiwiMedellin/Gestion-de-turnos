@model ShiftManagement.Models.User
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <h2 class="mb-4">Register</h2>

        @if (TempData["Warning"] != null)
        {
            <div class="alert alert-warning">@TempData["Warning"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form method="post" asp-action="Register">
            <div class="mb-3">
                <label class="form-label">Document Type</label>
                <select asp-for="DocumentType" class="form-select">
                    <option value="0">National ID</option>
                    <option value="1">Passport</option>
                    <option value="2">Foreign ID</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Document Number</label>
                <input asp-for="DocumentNumber" type="text" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Full Name</label>
                <input asp-for="Fullname" type="text" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Phone</label>
                <input asp-for="Phone" type="text" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input asp-for="Email" type="email" class="form-control" />
            </div>
            <button type="submit" class="btn btn-success w-100">Register</button>
        </form>

        <div class="mt-3 text-center">
            <a asp-controller="Turn" asp-action="Index">Already registered? Request your turn</a>
        </div>
    </div>
</div>
