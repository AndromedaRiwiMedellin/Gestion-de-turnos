@using ShiftManagement.Models
@{
    ViewData["Title"] = "Panel del Asesor";
    var waiting = ViewBag.WaitingTurns as List<Turn> ?? new();
    var current = ViewBag.CurrentTurn as Turn;
    var history = ViewBag.History as List<Turn> ?? new();

    var currentBorderColor = current?.Status == Status.InProgress ? "#198754"
                           : current?.Status == Status.Called ? "#ffc107"
                           : "#6c757d";
}

<div class="d-flex flex-column align-items-center mb-4 text-center">
    <h4 class="mb-1 fw-bold">Panel del Asesor</h4>

    @if (current != null)
    {
        <span class="badge bg-success rounded-pill">En sesión</span>
    }
    else
    {
        <span class="badge bg-secondary rounded-pill">Libre</span>
    }
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Info"] != null)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        @TempData["Info"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">

    @* Queue *@
    <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0 rounded-4">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center rounded-top-4">
                <span class="section-label">Cola de espera</span>
                <span class="badge bg-primary rounded-pill">@waiting.Count</span>
            </div>

            <div class="card-body">
                <form id="callNextForm" method="post" asp-action="CallNext">
                    <button id="callNextButton"
                            type="submit"
                            class="btn btn-primary w-100 mb-3 rounded-pill"
                            @(current != null || !waiting.Any() ? "disabled" : "")>
                        &#9658; Llamar siguiente
                    </button>
                </form>

                @if (waiting.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var t in waiting)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span class="fw-bold fs-5">@t.Code</span>
                                <small class="text-muted">@t.CreatedAt.ToLocalTime().ToString("HH:mm")</small>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted text-center mt-3 small">Sin turnos en espera.</p>
                }
            </div>
        </div>
    </div>

    @* Current turn *@
    <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0 rounded-4">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center rounded-top-4">
                <span class="section-label">Turno actual</span>

                @if (current?.Status == Status.Called)
                {
                    <span class="badge bg-warning text-dark rounded-pill">Llamado</span>
                }
                else if (current?.Status == Status.InProgress)
                {
                    <span class="badge bg-success rounded-pill">En atención</span>
                }
            </div>

            <div class="card-body text-center">
                @if (current == null)
                {
                    <p class="text-muted mt-5 small">Ningún turno activo.</p>
                }
                else
                {
                    <h1 class="display-1 fw-black text-primary my-3">@current.Code</h1>

                    @if (current.User != null)
                    {
                        <div class="text-start border rounded-3 p-3 mb-3 small bg-light">
                            <div class="mb-1">
                                <span class="text-muted">Nombre:</span>
                                <strong>@current.User.Fullname</strong>
                            </div>

                            <div class="mb-1">
                                <span class="text-muted">Documento:</span>
                                @current.User.DocumentType — @current.User.DocumentNumber
                            </div>

                            @if (!string.IsNullOrWhiteSpace(current.User.Phone))
                            {
                                <div class="mb-1">
                                    <span class="text-muted">Teléfono:</span>
                                    @current.User.Phone
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(current.User.Email))
                            {
                                <div>
                                    <span class="text-muted">Email:</span>
                                    @current.User.Email
                                </div>
                            }

                            <a asp-action="EditUser"
                               asp-route-id="@current.User.Id"
                               class="btn btn-sm btn-outline-secondary mt-2 w-100 rounded-pill">
                                Editar datos
                            </a>
                        </div>
                    }

                    @if (current.Status == Status.Called)
                    {
                        <form method="post" asp-action="StartAttention" asp-route-id="@current.Id" class="mb-2">
                            <button type="submit" class="btn btn-success w-100 rounded-pill">
                                Iniciar atención
                            </button>
                        </form>

                        <form method="post" asp-action="CancelTurn" asp-route-id="@current.Id">
                            <button type="submit" class="btn btn-outline-danger w-100 rounded-pill">
                                Cancelar turno
                            </button>
                        </form>
                    }
                    else if (current.Status == Status.InProgress)
                    {
                        <form method="post" asp-action="FinishTurn" asp-route-id="@current.Id" class="mb-2">
                            <div class="mb-3 text-start">
                                <label class="form-label small text-muted">
                                    Comentario (opcional)
                                </label>

                                <textarea name="message"
                                          class="form-control form-control-sm rounded-3"
                                          rows="2"
                                          placeholder="Observaciones del turno..."></textarea>
                            </div>

                            <button type="submit" class="btn btn-success w-100 rounded-pill">
                                Finalizar turno
                            </button>
                        </form>

                        <form method="post" asp-action="CancelTurn" asp-route-id="@current.Id">
                            <button type="submit" class="btn btn-outline-danger w-100 rounded-pill">
                                Cancelar turno
                            </button>
                        </form>
                    }
                }
            </div>
        </div>
    </div>

    @* History *@
    <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0 rounded-4">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center rounded-top-4">
                <span class="section-label">Historial de hoy</span>
                <span class="badge bg-secondary rounded-pill">@history.Count</span>
            </div>

            <div class="card-body p-0">
                @if (history.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var t in history)
                        {
                            <li class="list-group-item px-3 py-2">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fw-bold">@t.Code</span>
                                    <small class="text-muted">@t.UpdatedAt.ToLocalTime().ToString("HH:mm")</small>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(t.Message))
                                {
                                    <small class="text-secondary d-block mt-1">
                                        @t.Message
                                    </small>
                                }
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted text-center py-4 mb-0 small">
                        Sin turnos finalizados hoy.
                    </p>
                }
            </div>
        </div>
    </div>

</div>

<script>
    let callNextSubmitted = false;

    const callNextForm = document.getElementById("callNextForm");
    const callNextButton = document.getElementById("callNextButton");

    if (callNextForm) {
        callNextForm.addEventListener("submit", async function (event) {
            if (callNextSubmitted) {
                return;
            }

            event.preventDefault();
            callNextSubmitted = true;

            if (callNextButton) {
                callNextButton.disabled = true;
                callNextButton.innerText = "Llamando turno...";
            }

            callNextForm.submit();
        });
    }
</script>