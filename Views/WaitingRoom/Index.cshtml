@model List<ShiftManagement.Models.Turn>
@{
    ViewData["Title"] = "Sala de Espera";
    var lastCalledTurns = ViewBag.LastCalledTurns as List<ShiftManagement.Models.Turn> ?? new List<ShiftManagement.Models.Turn>();
    var currentTurnCode = (string)(ViewBag.CurrentTurn?.Code ?? "");
    bool hasTurn = !string.IsNullOrEmpty(currentTurnCode);
}

<style>
    @@keyframes pulse-ring {
        0%   { box-shadow: 0 0 0 0 rgba(32, 201, 151, 0.5); }
        70%  { box-shadow: 0 0 0 30px rgba(32, 201, 151, 0); }
        100% { box-shadow: 0 0 0 0 rgba(32, 201, 151, 0); }
    }

    .hero-now-serving {
        background: #0d1b2a;
        border-radius: 1rem;
        min-height: 220px;
    }

    .hero-now-serving.has-turn {
        animation: pulse-ring 2.5s infinite;
    }

    .hero-code {
        font-size: clamp(5rem, 14vw, 10rem);
        font-weight: 900;
        letter-spacing: 0.06em;
        color: #20c997;
        line-height: 1;
    }
</style>

@* Full-width hero: current turn *@
<div class="hero-now-serving d-flex flex-column align-items-center justify-content-center mb-4 p-4 @(hasTurn ? "has-turn" : "")">
    <p class="section-label text-secondary mb-3">&#9733; En atención ahora &#9733;</p>
    @if (hasTurn)
    {
        <div class="hero-code">@currentTurnCode</div>
    }
    else
    {
        <p class="text-secondary fs-4 mb-0">Sin turno activo</p>
    }
</div>

<div class="row g-4">

    @* Left: carousel + last called *@
    <div class="col-md-7">

        <div id="wrc" class="carousel slide rounded-3 mb-3 overflow-hidden" data-bs-ride="carousel" data-bs-interval="5000">
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <div class="d-flex align-items-center justify-content-center bg-primary text-white" style="height:140px">
                        <div class="text-center px-4">
                            <div class="fw-bold fs-5 mb-1">&#127979; Bienvenido</div>
                            <small>Gracias por elegirnos. Su turno será atendido pronto.</small>
                        </div>
                    </div>
                </div>
                <div class="carousel-item">
                    <div class="d-flex align-items-center justify-content-center" style="height:140px; background:#1a1a2e;">
                        <div class="text-center text-white px-4">
                            <div class="section-label text-secondary mb-2">Turnos en espera</div>
                            <div class="display-4 fw-black">@Model.Count</div>
                        </div>
                    </div>
                </div>
                <div class="carousel-item">
                    <div class="d-flex align-items-center justify-content-center bg-success text-white" style="height:140px">
                        <div class="text-center px-4">
                            <div class="fw-bold fs-5 mb-1">&#9203; Su tiempo importa</div>
                            <small>Estamos trabajando para atenderle cuanto antes.</small>
                        </div>
                    </div>
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#wrc" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#wrc" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-3">
                <span class="section-label">&#128276; Últimos llamados</span>
            </div>
            <div class="card-body p-0">
                @if (lastCalledTurns.Any())
                {
                    <ul class="list-group list-group-flush">
                        @for (int i = 0; i < lastCalledTurns.Count; i++)
                        {
                            var turn = lastCalledTurns[i];
                            <li class="list-group-item d-flex align-items-center py-3 px-3">
                                <span class="badge @(i == 0 ? "bg-success" : "bg-secondary") me-3">@(i + 1)</span>
                                <span class="fs-4 fw-bold @(i == 0 ? "text-success" : "text-secondary")">@turn.Code</span>
                                @if (i == 0)
                                {
                                    <span class="ms-auto badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 small">Reciente</span>
                                }
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted text-center py-4 mb-0 small">Sin turnos llamados aún.</p>
                }
            </div>
        </div>

    </div>

    @* Right: waiting queue *@
    <div class="col-md-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                <span class="section-label">Cola de espera</span>
                <span class="badge bg-dark rounded-pill">@Model.Count</span>
            </div>
            <div class="card-body p-0">
                @if (Model.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var turn in Model)
                        {
                            <li class="list-group-item py-3 px-3">
                                <span class="fs-5 fw-bold text-dark">@turn.Code</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted text-center py-4 mb-0 small">No hay turnos en espera.</p>
                }
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>setTimeout(function () { location.reload(); }, 10000);</script>
}
