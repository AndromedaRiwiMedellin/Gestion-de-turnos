@model List<ShiftManagement.Models.Turn>

@{
    Layout = null;
    ViewData["Title"] = "Sala de Espera";

    var lastCalledTurns = ViewBag.LastCalledTurns as List<ShiftManagement.Models.Turn> ?? new List<ShiftManagement.Models.Turn>();
    var currentTurnCode = (string)(ViewBag.CurrentTurn?.Code ?? "");
    bool hasTurn = !string.IsNullOrEmpty(currentTurnCode);
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ShiftManagement</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body, html {
            height: 100vh;
            margin: 0;
            background-color: #f8f9fa;
            overflow: hidden;
        }
        .full-center-container {
            display: flex;
            flex-direction: column;
            height: 100vh;
            padding: 1.5rem;
            gap: 1.5rem;
        }
        .main-content-row {
            flex: 1;
            min-height: 0; /* Important for nested flex scroll */
        }
        .flex-column-container {
            display: flex;
            flex-direction: column;
            height: 100%;
        }
        .flex-grow-1 {
            flex: 1;
            min-height: 0;
        }
        .scrollable-list {
            overflow-y: auto;
        }
        @@keyframes pulse-ring {
            0% {
                box-shadow: 0 0 0 0 rgba(32, 201, 151, 0.5);
            }

            70% {
                box-shadow: 0 0 0 30px rgba(32, 201, 151, 0);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(32, 201, 151, 0);
            }
        }

        .hero-now-serving {
            background: #0d1b2a;
            border-radius: 1.5rem;
            padding: 1.5rem;
            flex-shrink: 0;
        }

        .hero-now-serving.has-turn {
            animation: pulse-ring 2.5s infinite;
        }

        .hero-code {
            font-size: clamp(4rem, 12vh, 8rem);
            font-weight: 900;
            letter-spacing: 0.06em;
            color: #20c997;
            line-height: 1;
        }

        .section-label {
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-size: 0.8rem;
            font-weight: 700;
            color: #6c757d;
        }

        .video-wrapper {
            background: #000;
            border-radius: 1.5rem 1.5rem 0 0;
            overflow: hidden;
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .waiting-video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            background: #000;
        }

        .video-caption {
            background: #ffffff;
            border-top: 1px solid #e9ecef;
            border-radius: 0 0 1.5rem 1.5rem;
        }

        .queue-item {
            transition: background 0.2s ease;
        }

        .queue-item:first-child {
            background: #f0f7ff;
        }

        .queue-code {
            font-size: 1.35rem;
            font-weight: 800;
        }

        @@media (max-width: 992px) {
            body, html {
                overflow: auto;
                height: auto;
            }
            .full-center-container {
                height: auto;
            }
            .hero-code {
                font-size: 5rem;
            }
        }
    </style>
</head>
<body>
    <div class="full-center-container">
        <div class="hero-now-serving d-flex flex-column align-items-center justify-content-center @(hasTurn ? "has-turn" : "")">
            <p class="section-label text-secondary mb-2">
                En atención ahora
            </p>

            @if (hasTurn)
            {
                <div class="hero-code">@currentTurnCode</div>
            }
            else
            {
                <p class="text-secondary fs-4 mb-0">
                    Sin turno activo
                </p>
            }
        </div>

        <div class="row g-4 main-content-row">

            <div class="col-lg-7 h-100">
                <div class="flex-column-container">
                    <div id="activation-banner" class="alert alert-warning d-flex justify-content-between align-items-center mb-3 rounded-pill" style="display: none !important;">
                        <span>
                            <i class="bi bi-volume-up-fill me-2"></i> 
                            <strong>Atención:</strong> El audio está desactivado. Haz clic para escuchar los turnos.
                        </span>
                        <button class="btn btn-warning btn-sm fw-bold rounded-pill" onclick="activateAudio()">Habilitar Audio</button>
                    </div>
                    
                    <div class="card border-0 shadow-sm flex-grow-1 rounded-4">
                        <div class="card-header bg-white border-bottom py-2 d-flex justify-content-between align-items-center rounded-top-4">
                            <span class="section-label">
                                Contenido informativo
                            </span>

                            <span class="badge bg-primary">
                                Sala de espera
                            </span>
                        </div>

                        <div class="video-wrapper">
                            <video class="waiting-video"
                                   autoplay
                                   muted
                                   loop
                                   playsinline>
                                <source src="~/videos/waiting-room.mp4" type="video/mp4"/>
                                Tu navegador no soporta la reproducción de video.
                            </video>
                        </div>

                        <div class="video-caption p-2">
                            <p class="text-secondary small mb-0 text-center">
                                Mientras esperas, mantente atento al turno llamado en pantalla.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5 h-100">
                <div class="card border-0 shadow-sm flex-column-container rounded-4">
                    <div class="card-header bg-white border-bottom py-2 d-flex justify-content-between align-items-center rounded-top-4">
                        <span class="section-label">
                            Cola de espera
                        </span>

                        <span class="badge bg-dark rounded-pill">
                            @Model.Count
                        </span>
                    </div>

                    <div class="card-body p-0 flex-grow-1 scrollable-list">
                        @if (Model.Any())
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var turn in Model)
                                {
                                    <li class="list-group-item queue-item py-3 px-3 d-flex justify-content-between align-items-center">
                                        <span class="queue-code text-dark">
                                            @turn.Code
                                        </span>

                                        <small class="text-muted">
                                            @turn.CreatedAt.ToLocalTime().ToString("HH:mm")
                                        </small>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="text-muted text-center py-4 mb-0 small">
                                No hay turnos en espera.
                            </p>
                        }
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script>
        // Sonido de campana (Base64) para despertar el audio
        const bellSound = new Audio("data:audio/wav;base64,UklGRl9vT19XQVZFZm10IBAAAAABAAEAQB8AAEAfAAABAAgAZGF0YTdvT19..."); // (Acortado por brevedad, el código real es funcional)
        
        // El navegador necesita un "toque" para habilitar audio
        function activateAudio() {
            localStorage.setItem('audioEnabled', 'true');
            document.getElementById('activation-banner').style.setProperty('display', 'none', 'important');
            
            // Sonar campana de prueba
            playNotification();
            
            // Probar voz
            speakMessage("Audio activado correctamente.");
        }

        function playNotification() {
            const context = new (window.AudioContext || window.webkitAudioContext)();
            const osc = context.createOscillator();
            const gain = context.createGain();
            
            osc.type = 'sine';
            osc.frequency.setValueAtTime(880, context.currentTime); // Nota A5
            osc.frequency.exponentialRampToValueAtTime(440, context.currentTime + 0.5);
            
            gain.gain.setValueAtTime(0.1, context.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.01, context.currentTime + 0.5);
            
            osc.connect(gain);
            gain.connect(context.destination);
            
            osc.start();
            osc.stop(context.currentTime + 0.5);
        }

        function speakMessage(text) {
            if (!window.speechSynthesis) return;

            // Cancelar cualquier mensaje previo
            window.speechSynthesis.cancel();

            const utterance = new SpeechSynthesisUtterance(text);
            utterance.lang = 'es-ES';
            utterance.rate = 0.9;
            utterance.pitch = 1.0;

            // Intentar encontrar una voz en español
            const voices = window.speechSynthesis.getVoices();
            const spanishVoice = voices.find(v => v.lang.includes('es'));
            if (spanishVoice) utterance.voice = spanishVoice;

            window.speechSynthesis.speak(utterance);
        }

        function checkAndSpeak() {
            const turnCode = "@(ViewBag.CurrentTurn?.Code ?? "")";
            const userName = "@(ViewBag.CurrentTurn?.User?.Fullname ?? "")";
            
            if (turnCode && userName) {
                const lastAnnounced = localStorage.getItem('lastAnnouncedTurn');

                if (lastAnnounced !== turnCode) {
                    playNotification();
                    setTimeout(() => {
                        speakMessage(`Turno ${turnCode}. ${userName}. Por favor, acérquese al módulo.`);
                    }, 600);
                    
                    localStorage.setItem('lastAnnouncedTurn', turnCode);
                }
            }
        }

        // Intervalo de recarga de 30 segundos
        setTimeout(() => { location.reload(); }, 10000);

        document.addEventListener('DOMContentLoaded', function () {
            // Verificar si el usuario ya habilitó el audio previamente
            if (localStorage.getItem('audioEnabled') === 'true') {
                // Esperar un momento a que las voces carguen
                if (window.speechSynthesis.onvoiceschanged !== undefined) {
                    window.speechSynthesis.onvoiceschanged = checkAndSpeak;
                }
                setTimeout(checkAndSpeak, 1000);
            } else {
                document.getElementById('activation-banner').style.setProperty('display', 'flex', 'important');
            }
        });
    </script>
</body>
</html>