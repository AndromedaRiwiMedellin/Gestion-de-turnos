@model List<ShiftManagement.Models.Turn>
@{
    ViewData["Title"] = "Waiting Room";
}

<meta http-equiv="refresh" content="10" />

<h2 class="mb-4">Waiting Room</h2>

<div class="card mb-4">
    <div class="card-header">Now Serving</div>
    <div class="card-body text-center">
        @if (ViewBag.CurrentTurn != null)
        {
            <h1 class="display-1 fw-bold">@ViewBag.CurrentTurn.Code</h1>
        }
        else
        {
            <p class="text-muted">No turn currently being served.</p>
        }
    </div>
</div>

<h5 class="mb-3">Waiting Queue</h5>

@if (Model.Any())
{
    <div class="row row-cols-auto g-3">
        @foreach (var turn in Model)
        {
            <div class="col">
                <div class="card text-center px-4 py-3">
                    <span class="fs-3 fw-bold">@turn.Code</span>
                </div>
            </div>
        }
    </div>
}
else
{
    <p class="text-muted">No turns in queue.</p>
}
