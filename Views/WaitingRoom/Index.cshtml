@model List<ShiftManagement.Models.Turn>
@{
    ViewData["Title"] = "Sala de Espera";
    var currentCode = ViewBag.CurrentTurn?.Code as string ?? "";
}

<meta http-equiv="refresh" content="30" />

<h4 class="mb-3 fw-semibold">Sala de Espera</h4>

<div class="row g-4 mb-4">

    <!-- Panel informativo / Video -->
    <div class="col-md-7">
        <div class="card h-100 position-relative" style="min-height:300px; overflow:hidden;">

            <!-- Siempre visible -->
            <div class="card-body d-flex flex-column justify-content-center align-items-center text-center py-5">
                <h2 class="display-6 fw-bold text-primary mb-4">Sistema de Gestión de Turnos</h2>
                <div class="row w-100 g-3">
                    <div class="col-6">
                        <div class="border rounded p-3">
                            <div class="fs-1 fw-bold text-secondary">@Model.Count</div>
                            <div class="text-muted small">Personas en espera</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="border rounded p-3">
                            <div class="fs-1 fw-bold text-primary">
                                @(string.IsNullOrEmpty(currentCode) ? "—" : currentCode)
                            </div>
                            <div class="text-muted small">Turno en atención</div>
                        </div>
                    </div>
                </div>
                <p class="text-muted mt-4 small">Gracias por su espera. Lo atenderemos en breve.</p>
            </div>

            <!-- Cubre el panel si el video carga; se elimina solo si falla -->
            <video autoplay loop muted playsinline onerror="this.remove()"
                   style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;">
                <source src="/media/promo.mp4" type="video/mp4">
            </video>

        </div>
    </div>

    <!-- Turno actual -->
    <div class="col-md-5">
        <div class="card h-100">
            <div class="card-header fw-semibold">Turno actual</div>
            <div class="card-body d-flex flex-column justify-content-center align-items-center text-center">
                @if (!string.IsNullOrEmpty(currentCode))
                {
                    <p class="text-muted small mb-1">Ahora atendiendo</p>
                    <h1 class="display-1 fw-bold text-primary">@currentCode</h1>
                    <p class="text-muted mt-2">Por favor pase al módulo de atención</p>
                }
                else
                {
                    <p class="text-muted fs-5">Sin turno activo</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- Cola de espera -->
<h5 class="mb-3">Cola de espera</h5>

@if (Model.Any())
{
    <div class="row row-cols-auto g-3">
        @foreach (var turn in Model)
        {
            <div class="col">
                <div class="card text-center px-4 py-3">
                    <span class="fs-3 fw-bold">@turn.Code</span>
                </div>
            </div>
        }
    </div>
}
else
{
    <p class="text-muted">Sin turnos en espera.</p>
}

<hr class="my-4" />

<div class="row g-3">

    <!-- Solicitar turno -->
    <div class="col-md-6">
        <button class="btn btn-primary w-100" type="button"
                data-bs-toggle="collapse" data-bs-target="#formTurno">
            Solicitar turno
        </button>
        <div class="collapse mt-3" id="formTurno">
            <div class="card card-body">
                <h6 class="mb-3">Ingresa tu documento</h6>
                <form method="post" asp-controller="Turn" asp-action="RequestTurn">
                    <div class="mb-3">
                        <label class="form-label">Tipo de documento</label>
                        <select name="documentType" class="form-select">
                            <option value="0">Cédula</option>
                            <option value="1">Pasaporte</option>
                            <option value="2">Cédula extranjería</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Número de documento</label>
                        <input name="documentNumber" type="text" class="form-control" required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Obtener turno</button>
                </form>
            </div>
        </div>
    </div>

    <!-- Registrar usuario -->
    <div class="col-md-6">
        <button class="btn btn-outline-secondary w-100" type="button"
                data-bs-toggle="collapse" data-bs-target="#formRegistro">
            Registrar nuevo usuario
        </button>
        <div class="collapse mt-3" id="formRegistro">
            <div class="card card-body">
                <h6 class="mb-3">Completa tus datos</h6>
                <form method="post" asp-controller="User" asp-action="Register">
                    <div class="mb-3">
                        <label class="form-label">Tipo de documento</label>
                        <select name="DocumentType" class="form-select">
                            <option value="0">Cédula</option>
                            <option value="1">Pasaporte</option>
                            <option value="2">Cédula extranjería</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Número de documento</label>
                        <input name="DocumentNumber" type="text" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nombre completo</label>
                        <input name="Fullname" type="text" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Teléfono</label>
                        <input name="Phone" type="text" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input name="Email" type="email" class="form-control" />
                    </div>
                    <button type="submit" class="btn btn-success w-100">Registrar</button>
                </form>
            </div>
        </div>
    </div>

</div>
