@{
    ViewData["Title"] = "Inicio";
}

<div class="container py-5">

    <section class="bg-primary text-white rounded-4 shadow-sm p-4 p-md-5 mb-5">
        <div class="row align-items-center g-4">
            <div class="col-lg-8">
                <span class="badge bg-light text-primary mb-3 px-3 py-2 rounded-pill">
                    Sistema de Gestión de Turnos
                </span>

                <h1 class="display-5 fw-bold mb-3">
                    Gestión eficiente de turnos para atención clínica
                </h1>

                <p class="lead mb-4">
                    Plataforma diseñada para registrar pacientes, generar turnos,
                    organizar la sala de espera y facilitar el proceso de atención.
                </p>

                <div class="d-flex flex-wrap gap-3">
                    <a asp-controller="Turn"
                       asp-action="Index"
                       class="btn btn-light btn-lg px-4 rounded-pill">
                        Solicitar turno
                    </a>

                    <a asp-controller="Advisor"
                       asp-action="Index"
                       class="btn btn-outline-light btn-lg px-4 rounded-pill">
                        Panel del asesor
                    </a>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="bg-white text-dark rounded-4 p-4 shadow-sm">
                    <h5 class="fw-bold mb-3">
                        Accesos rápidos
                    </h5>

                    <div class="d-grid gap-2">
                        <a asp-controller="Turn"
                           asp-action="Index"
                           class="btn btn-primary rounded-pill">
                            Entrada de pacientes
                        </a>

                        <a asp-controller="WaitingRoom"
                           asp-action="Index"
                           class="btn btn-outline-primary rounded-pill">
                            Sala de espera
                        </a>

                        <a asp-controller="Advisor"
                           asp-action="Index"
                           class="btn btn-outline-primary rounded-pill">
                            Atención del asesor
                        </a>

                        <a asp-controller="Home"
                           asp-action="Privacy"
                           class="btn btn-outline-secondary rounded-pill">
                            Privacidad
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="mb-5">
        <div class="text-center mb-4">
            <h2 class="fw-bold">
                Módulos del sistema
            </h2>

            <p class="text-secondary mb-0">
                Accede a las funciones principales del sistema de gestión de turnos.
            </p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm rounded-4">
                    <div class="card-body p-4 d-flex flex-column">
                        <span class="badge bg-primary align-self-start mb-3 rounded-pill">
                            Entrada
                        </span>

                        <h5 class="card-title fw-bold">
                            Registro y ticket
                        </h5>

                        <p class="card-text text-secondary flex-grow-1">
                            Registra al paciente, valida su documento, selecciona el tipo
                            de atención y genera el turno correspondiente.
                        </p>

                        <a asp-controller="Turn"
                           asp-action="Index"
                           class="btn btn-primary w-100 mt-3 rounded-pill">
                            Ir al módulo
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm rounded-4">
                    <div class="card-body p-4 d-flex flex-column">
                        <span class="badge bg-success align-self-start mb-3 rounded-pill">
                            Atención
                        </span>

                        <h5 class="card-title fw-bold">
                            Panel del asesor
                        </h5>

                        <p class="card-text text-secondary flex-grow-1">
                            Visualiza turnos pendientes, llama al siguiente paciente,
                            inicia la atención y finaliza el proceso.
                        </p>

                        <a asp-controller="Advisor"
                           asp-action="Index"
                           class="btn btn-success w-100 mt-3 rounded-pill">
                            Abrir panel
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm rounded-4">
                    <div class="card-body p-4 d-flex flex-column">
                        <span class="badge bg-dark align-self-start mb-3 rounded-pill">
                            Sala
                        </span>

                        <h5 class="card-title fw-bold">
                            Sala de espera
                        </h5>

                        <p class="card-text text-secondary flex-grow-1">
                            Muestra los turnos en cola y el turno actual para orientar
                            a los pacientes durante la espera.
                        </p>

                        <a asp-controller="WaitingRoom"
                           asp-action="Index"
                           class="btn btn-dark w-100 mt-3 rounded-pill">
                            Ver sala
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4 p-md-5">
            <div class="row align-items-center g-4">
                <div class="col-lg-5">
                    <h3 class="fw-bold mb-3">
                        Flujo de atención
                    </h3>

                    <p class="text-secondary mb-0">
                        El sistema organiza el proceso desde el ingreso del paciente
                        hasta la finalización de la atención por parte del asesor.
                    </p>
                </div>

                <div class="col-lg-7">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="border rounded-3 p-3 h-100 bg-light">
                                <div class="fw-bold text-primary mb-1">
                                    1. Registro
                                </div>
                                <div class="text-secondary small">
                                    El paciente ingresa sus datos básicos.
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded-3 p-3 h-100 bg-light">
                                <div class="fw-bold text-primary mb-1">
                                    2. Tipo de ticket
                                </div>
                                <div class="text-secondary small">
                                    Se selecciona el servicio requerido.
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded-3 p-3 h-100 bg-light">
                                <div class="fw-bold text-primary mb-1">
                                    3. Turno generado
                                </div>
                                <div class="text-secondary small">
                                    Se crea el ticket digital y físico.
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded-3 p-3 h-100 bg-light">
                                <div class="fw-bold text-primary mb-1">
                                    4. Atención
                                </div>
                                <div class="text-secondary small">
                                    El asesor llama y finaliza el turno.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

</div>